server.items.Circuit_Pusher_Piston_Extended.name = Extended Piston
server.items.Circuit_Pusher_Piston_Extended.description = A piston in its extended state.

server.items.Circuit_Sticky_Piston.name = Sticky Piston
server.items.Circuit_Sticky_Piston.description = A piston that pushes and pulls blocks when powered.

server.items.Circuit_Sticky_Piston_Extended.name = Extended Sticky Piston
server.items.Circuit_Sticky_Piston_Extended.description = A sticky piston in its extended state.

server.items.Circuit_Piston_Head.name = Piston Head
server.items.Circuit_Piston_Head.description = The head of a piston.

