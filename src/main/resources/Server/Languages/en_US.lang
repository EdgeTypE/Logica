# Circuit Items
server.items.Circuit_Wire.name = Wire
server.items.Circuit_Wire.description = A basic wire for conducting circuit signals.

server.items.Circuit_Wire_Block.name = Wire Block
server.items.Circuit_Wire_Block.description = A wire in full block form. Acts like a normal wire.

server.items.activator_block.name = Activator Block
server.items.activator_block.description = An activator block that can be toggled on and off.

server.items.Circuit_Golden_Wire.name = Golden Wire
server.items.Circuit_Golden_Wire.description = A golden wire that instantly transmits circuit signals.

server.items.Circuit_Button.name = Button
server.items.Circuit_Button.description = A button that emits a short circuit pulse when pressed.

server.items.Circuit_Lever.name = Lever
