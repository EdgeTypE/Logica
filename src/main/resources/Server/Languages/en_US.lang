server.items.Circuit_Vacuum_Pipe.name = Vacuum Pipe
server.items.Circuit_Vacuum_Pipe.description = A vacuum pipe that pulls items from nearby blocks.

server.items.Circuit_Pressure_Plate.name = Pressure Plate
server.items.Circuit_Pressure_Plate.description = A pressure plate that activates when stepped on.

# Logic Gates
server.items.Circuit_Gate_AND.name = AND Gate
server.items.Circuit_Gate_AND.description = A logic gate that outputs power only when all inputs are powered.

server.items.Circuit_Gate_OR.name = OR Gate
server.items.Circuit_Gate_OR.description = A logic gate that outputs power when any input is powered.

server.items.Circuit_Gate_NOT.name = NOT Gate
server.items.Circuit_Gate_NOT.description = A logic gate that inverts the input signal.

server.items.Circuit_Gate_NOT_On.name = NOT Gate (On)
server.items.Circuit_Gate_NOT_On.description = A NOT gate in its active state.

server.items.Circuit_Gate_NAND.name = NAND Gate
server.items.Circuit_Gate_NAND.description = A logic gate that outputs power unless all inputs are powered.

server.items.Circuit_Gate_NOR.name = NOR Gate
server.items.Circuit_Gate_NOR.description = A logic gate that outputs power only when no inputs are powered.

server.items.Circuit_Gate_XOR.name = XOR Gate
server.items.Circuit_Gate_XOR.description = A logic gate that outputs power when inputs differ.

server.items.Circuit_Gate_XNOR.name = XNOR Gate
server.items.Circuit_Gate_XNOR.description = A logic gate that outputs power when inputs are the same.

server.items.Circuit_Gate_Buffer.name = Buffer Gate
server.items.Circuit_Gate_Buffer.description = A logic gate that passes through the input signal.

